# ─────────────────────────────────────────────────────────────────────
# LegalPacers — Portal de marcas
# Copiar a .env y completar antes de levantar la app.
# ─────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
# URL pública del sitio (para construir back_urls de MP, magic links, etc.)
APP_BASE_URL=https://tu-dominio.com
FLASK_SECRET_KEY=cambiar-por-string-aleatorio-de-32-chars-minimo
FLASK_ENV=production
DEBUG=False
PORT=5000

# ── Base de datos ────────────────────────────────────────────────────
# Railway agrega DATABASE_URL automáticamente cuando provisionas Postgres.
# Si la dejas vacía, la app cae a SQLite local (marcas.db) — solo dev.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Anthropic (Claude) ───────────────────────────────────────────────
# Necesaria para: similitud conceptual (Nivel 2), pre-análisis legal,
# sugerencia de clases Nice. Obtenerla en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini (Google AI) ───────────────────────────────────────────────
# Provider preferido para similitud conceptual.
# Tier gratis: 1500 requests/día con gemini-2.5-flash.
# Cuenta paga: usar gemini-2.5-pro para análisis más profundo (más caro
# por request, ~3x flash, pero respeta mejor el marco de confundibilidad).
# Las pautas de análisis se cargan automáticamente via systemInstruction
# (no hace falta crear un Gem manualmente — se hace por API).
# Obtener key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 'gemini' (default), 'claude', 'gemini-only' o 'claude-only'
CONCEPTUAL_PROVIDER=gemini

# ── MercadoPago ──────────────────────────────────────────────────────
# Sandbox:    TEST-...  (developers.mercadopago.com.ar → Tus integraciones)
# Producción: APP_USR-...
# Si la dejás vacía, la app activa el modo dev: muestra /dev/checkout con
# 3 botones (approve/pending/reject) para probar el flujo sin pagar.
MP_ACCESS_TOKEN=

# Forzar modo dev aunque haya token (útil para debugging)
MP_DEV_MODE=false

# ── Resend (email transaccional) ─────────────────────────────────────
# Si está seteada, se usa Resend para todos los emails. Si no, cae a SMTP.
# Crear API key en https://resend.com (necesita dominio verificado)
RESEND_API_KEY=

FROM_EMAIL=noreply@legalpacers.com
FROM_NAME=LegalPacers

# ── SMTP (fallback de Resend; o Gmail con app password) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@legalpacers.com
SMTP_PASS=your-app-password

# Email del equipo legal — recibe notificaciones de cotizaciones de Nivel 3
EQUIPO_LEGAL_EMAIL=contacto@legalpacers.com

# Email interno usado por flujos previos (compatibilidad)
INTERNAL_NOTIFY_EMAIL=contacto@legalpacers.com

# ── Precios (ARS) ────────────────────────────────────────────────────
# Configurables sin tocar código. Cualquier cambio se refleja en la próxima
# carga de página y en los nuevos pagos. Pagos ya creados conservan su monto.
PRECIO_INFORME_COMPLETO=9900

# Vigilancia mensual — 3 tiers
PRECIO_VIGILANCIA_INDIVIDUAL=4900     # 1 marca
PRECIO_VIGILANCIA_MULTI=9900          # hasta 3 marcas
PRECIO_VIGILANCIA_PORTFOLIO=20000     # hasta 10 marcas
# Anual con 2 meses gratis (suscriptor paga 10 meses)

# Legacy (mantener compatibilidad; no usar para nuevas suscripciones)
PRECIO_CONSULTA_COMPLETA=9900
PRECIO_VIGILANCIA_MARCA=4900
PRECIO_PREMIUM_MES=9900
PRECIO_PREMIUM_ANUAL=99000

# Cap de marcas por tier (informativo, no enforced rígido)
PREMIUM_VIGILANCIA_CAP=10

# Rate-limit free: amplio para evitar bloquear UX, sólo previene scraping
FREE_SEARCH_LIMIT=50
FREE_SEARCH_WINDOW_HOURS=24

# Descuento del recordatorio post-búsqueda free (a los 15 días)
INFORME_RECORDATORIO_DIAS=15
INFORME_RECORDATORIO_DESCUENTO_PCT=10

# ── WhatsApp alerts (Twilio) ─────────────────────────────────────────
# Opcional: si dejás esto vacío, las alertas solo se envían por email.
# Para activarlo: crear cuenta en Twilio, comprar/registrar un número
# WhatsApp Business, y poner las credenciales abajo.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Admin ────────────────────────────────────────────────────────────
# Clave para disparar importaciones manuales desde /admin
ADMIN_KEY=cambiar-por-string-secreto

# ── Importador de boletines (Windows Task Scheduler local) ───────────
# El script scripts/import-boletin.py se conecta al mismo DATABASE_URL
# que la app web — no hace falta repetir nada acá.
# Para registrar la tarea programada (corre como admin desde PowerShell):
#   .\scripts\install-task-scheduler.ps1
