ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (Railway adds this automatically when you provision a DB)
# For local dev, leave empty to use SQLite (marcas.db)
DATABASE_URL=postgresql://user:password@host:5432/dbname
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@legalpacers.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@legalpacers.com
INTERNAL_NOTIFY_EMAIL=contacto@legalpacers.com
FLASK_SECRET_KEY=change-me-to-random-string
DEBUG=False

# Admin key to trigger bulk import via /api/admin/import
ADMIN_KEY=change-me-to-secret-key

# Mercado Pago (Preapproval / suscripción recurrente)
MP_ACCESS_TOKEN=APP_USR-xxx
PUBLIC_BASE_URL=https://marcas.legalpacers.com
PREMIUM_PRICE_ARS=9900
PREMIUM_DAYS=30

# Set to false when serving over plain HTTP in local dev
SESSION_COOKIE_SECURE=true
