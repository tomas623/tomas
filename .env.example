# ─────────────────────────────────────────────────────────────────────
# LegalPacers — Portal de marcas
# Copiar a .env y completar antes de levantar la app.
# ─────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
# URL pública del sitio (para construir back_urls de MP, magic links, etc.)
APP_BASE_URL=https://tu-dominio.com
FLASK_SECRET_KEY=cambiar-por-string-aleatorio-de-32-chars-minimo
FLASK_ENV=production
DEBUG=False
PORT=5000

# ── Base de datos ────────────────────────────────────────────────────
# Railway agrega DATABASE_URL automáticamente cuando provisionas Postgres.
# Si la dejas vacía, la app cae a SQLite local (marcas.db) — solo dev.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Anthropic (Claude) ───────────────────────────────────────────────
# Necesaria para: similitud conceptual (Nivel 2), pre-análisis legal,
# sugerencia de clases Nice. Obtenerla en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── MercadoPago ──────────────────────────────────────────────────────
# Sandbox:    TEST-...  (developers.mercadopago.com.ar → Tus integraciones)
# Producción: APP_USR-...
# Si la dejás vacía, la app activa el modo dev: muestra /dev/checkout con
# 3 botones (approve/pending/reject) para probar el flujo sin pagar.
MP_ACCESS_TOKEN=

# Forzar modo dev aunque haya token (útil para debugging)
MP_DEV_MODE=false

# ── Resend (email transaccional) ─────────────────────────────────────
# Si está seteada, se usa Resend para todos los emails. Si no, cae a SMTP.
# Crear API key en https://resend.com (necesita dominio verificado)
RESEND_API_KEY=

FROM_EMAIL=noreply@legalpacers.com
FROM_NAME=LegalPacers

# ── SMTP (fallback de Resend; o Gmail con app password) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@legalpacers.com
SMTP_PASS=your-app-password

# Email del equipo legal — recibe notificaciones de cotizaciones de Nivel 3
EQUIPO_LEGAL_EMAIL=contacto@legalpacers.com

# Email interno usado por flujos previos (compatibilidad)
INTERNAL_NOTIFY_EMAIL=contacto@legalpacers.com

# ── Precios (ARS) ────────────────────────────────────────────────────
# Configurables sin tocar código. Cualquier cambio se refleja en la próxima
# carga de página y en los nuevos pagos. Pagos ya creados conservan su monto.
PRECIO_CONSULTA_COMPLETA=15000
PRECIO_VIGILANCIA_MARCA=20000
PRECIO_VIGILANCIA_PORTFOLIO=50000
# Suscripción premium (consultas ilimitadas + vigilancia hasta 3 marcas)
PRECIO_PREMIUM_MES=9900
# Búsquedas gratuitas por IP en una ventana (rolling window)
# 168 horas = 1 semana
FREE_SEARCH_LIMIT=3
FREE_SEARCH_WINDOW_HOURS=168

# ── Admin ────────────────────────────────────────────────────────────
# Clave para disparar importaciones manuales desde /admin
ADMIN_KEY=cambiar-por-string-secreto

# ── Importador de boletines (Windows Task Scheduler local) ───────────
# El script scripts/import-boletin.py se conecta al mismo DATABASE_URL
# que la app web — no hace falta repetir nada acá.
# Para registrar la tarea programada (corre como admin desde PowerShell):
#   .\scripts\install-task-scheduler.ps1
