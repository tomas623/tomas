# ===========================================================================
# Backend Node + Express (BUILD_SPEC.md sección 5)
# ===========================================================================
PORT=3000
MP_ACCESS_TOKEN=            # Mercado Pago; vacío = modo stub (sin credenciales)
PRECIO_INFORME=19900
PRECIO_REGISTRO=120000
BASE_URL=http://localhost:3000
WHATSAPP_NOTIFY=            # opcional: número/endpoint para avisos de lead
SQLITE_PATH=                # opcional: override del path de la DB (default ./data/legalpacers.db)
ADMIN_TOKEN=                # protege /api/admin/leads y el alta de admin/operador

# ===========================================================================
# Motor de vigilancia + panel (BUILD_SPEC_MOTOR.md §8)
# ===========================================================================
SESSION_SECRET=              # firma de cookies de sesión (cambialo en prod)
SEED_ADMIN_EMAIL=admin@legalpacers.com
SEED_ADMIN_PASSWORD=admin12345

# IA — etapa 2 del matching (vacío = modo stub)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Mail — alertas (vacío = stub)
RESEND_API_KEY=
MAIL_FROM=alertas@legalpacers.com

# WhatsApp Cloud API — alertas (vacío = stub)
WA_PHONE_NUMBER_ID=
WA_TOKEN=
WA_TEMPLATE_ALERTA=alerta_marca

# Scheduler — miércoles 9:00 (configurable)
CRON_MONITOREO=0 9 * * 3

# Puente con la app Python: si está seteado, el scheduler cada CRON_PUENTE_PYTHON
# detecta boletines nuevos en marcas.db y los importa + procesa automáticamente.
PYTHON_DB_PATH=./marcas.db
CRON_PUENTE_PYTHON=0 * * * *      # cada hora en punto

# ===========================================================================
# App Python/Flask heredada (no la usa el backend Node — convive aparte)
# ===========================================================================
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:password@host:5432/dbname
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@legalpacers.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@legalpacers.com
INTERNAL_NOTIFY_EMAIL=contacto@legalpacers.com
FLASK_SECRET_KEY=change-me-to-random-string
DEBUG=False
ADMIN_KEY=change-me-to-secret-key
PUBLIC_BASE_URL=https://marcas.legalpacers.com
PREMIUM_PRICE_ARS=9900
PREMIUM_DAYS=30
SESSION_COOKIE_SECURE=true
